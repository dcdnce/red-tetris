{
  "name": "red-tetris",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "server/index.js",
  "scripts": {
    "dev:server": "nodemon server/index.js",
    "dev:client": "vite --config client/vite.config.js dev",
    "dev": "concurrently --kill-others-on-fail \"npm:dev:server\" \"npm:dev:client\"",
    "build:client": "vite build --config client/vite.config.js",
    "build": "npm run build:client",
    "start": "NODE_ENV=production node server/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format:check": "prettier --check \"**/*.{js,jsx,json,css,md}\"",
    "format:write": "prettier --write \"**/*.{js,jsx,json,css,md}\"",
    "preview": "vite preview --config client/vite.config.js"
  }, 
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dcdnce/red-tetris.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/dcdnce/red-tetris/issues"
  },
  "homepage": "https://github.com/dcdnce/red-tetris#readme",
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.1",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "vite": "^6.2.4"
  }
}
